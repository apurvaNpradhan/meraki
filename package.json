{
  "name": "meraki",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "biome check --write .",
    "prepare": "husky",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @meraki/db db:push",
    "db:studio": "turbo -F @meraki/db db:studio",
    "db:generate": "turbo -F @meraki/db db:generate",
    "db:migrate": "turbo -F @meraki/db db:migrate",
    "deploy": "turbo -F @meraki/infra deploy",
    "destroy": "turbo -F @meraki/infra destroy"
  },
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:",
    "@meraki/env": "workspace:*"
  },
  "devDependencies": {
    "turbo": "^2.6.3",
    "@biomejs/biome": "^2.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "typescript": "catalog:",
    "@types/node": "catalog:",
    "@meraki/config": "workspace:*",
    "@cloudflare/workers-types": "catalog:"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write ."
    ]
  },
  "packageManager": "pnpm@10.25.0"
}
